<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:EasyGuitarTuner.Controls"
             x:Class="EasyGuitarTuner.MainPage"
             BackgroundColor="#1A120B"
             Shell.NavBarIsVisible="False"
             Title="Easy Guitar Tuner">

    <AbsoluteLayout>

        <controls:AnalogMeterView
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            NeedleAngle="{Binding NeedleAngle}" />

        <Grid
            AbsoluteLayout.LayoutBounds="0.5,0.73,0.85,0.12"
            AbsoluteLayout.LayoutFlags="All"
            ColumnDefinitions="*,2*,*"
            VerticalOptions="Center">

            <VerticalStackLayout Grid.Column="0"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Margin="0,6,0,0"
                                 Spacing="0">
                <Label Text="STANDARD"
                       HorizontalOptions="Center"
                       FontSize="7"
                       TextColor="#C9B68A" />
                <Label Text="440 Hz"
                       HorizontalOptions="Center"
                       FontSize="9"
                       TextColor="#C9B68A" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="-2">
                <Label HorizontalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding NoteText}"
                                  FontSize="20"
                                  FontAttributes="Bold"
                                  TextColor="{Binding NoteColor}" />
                            <Span Text="{Binding OctaveText}"
                                  FontSize="10"
                                  FontAttributes="Bold"
                                  TextColor="{Binding NoteColor}" />
                            <Span Text="{Binding NoteSeparatorText}"
                                  FontSize="20"
                                  FontAttributes="Bold"
                                  TextColor="{Binding NoteColor}" />
                            <Span Text="{Binding LatinNoteText}"
                                  FontSize="20"
                                  FontAttributes="Bold"
                                  TextColor="{Binding NoteColor}" />
                            <Span Text="{Binding OctaveText}"
                                  FontSize="10"
                                  FontAttributes="Bold"
                                  TextColor="{Binding NoteColor}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label Text="{Binding FrequencyText}"
                       HorizontalOptions="Center"
                       FontSize="12"
                       TextColor="{Binding FrequencyColor}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Margin="0,6,0,0"
                                 Spacing="0">
                <Label Text="{Binding CentsText}"
                       HorizontalOptions="Center"
                       FontSize="11"
                       TextColor="#C9B68A" />
                <Label Text="CENTS"
                       HorizontalOptions="Center"
                       FontSize="7"
                       TextColor="#C9B68A" />
            </VerticalStackLayout>

        </Grid>

    </AbsoluteLayout>

</ContentPage>
