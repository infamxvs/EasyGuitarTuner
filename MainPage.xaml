<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:EasyGuitarTuner.Controls"
             x:Class="EasyGuitarTuner.MainPage"
             BackgroundColor="#1A120B"
             Shell.NavBarIsVisible="False"
             Title="Easy Guitar Tuner">

    <AbsoluteLayout>

        <controls:AnalogMeterView
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            NeedleAngle="{Binding NeedleAngle}" />

        <VerticalStackLayout
            AbsoluteLayout.LayoutBounds="0.5,0.69,0.7,0.12"
            AbsoluteLayout.LayoutFlags="All"
            Spacing="2"
            VerticalOptions="Center">

            <Label Text="{Binding FrequencyText}"
                   HorizontalOptions="Center"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#F5E6C8" />

            <Label Text="{Binding StatusText}"
                   HorizontalOptions="Center"
                   FontSize="14"
                   TextColor="#C9B68A" />

        </VerticalStackLayout>

        <Button Text="{Binding ToggleButtonText}"
                Command="{Binding ToggleListeningCommand}"
                AbsoluteLayout.LayoutBounds="0.5,0.9,0.7,0.09"
                AbsoluteLayout.LayoutFlags="All"
                BackgroundColor="#3A2A18"
                TextColor="#F5E6C8"
                BorderColor="#8A6A3A"
                BorderWidth="1"
                CornerRadius="10"
                FontSize="16" />

    </AbsoluteLayout>

</ContentPage>
